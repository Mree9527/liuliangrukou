# Money Engine v2.0 — Environment Configuration
# Copy to .env and fill in your credentials

# Site URL (used for sitemap, canonical URLs, tracking)
SITE_URL=https://mree9527.github.io/liuliangrukou

# Amazon Associates tag (change after registering at amazon.com/associates)
AMAZON_TAG=smarthome-20

# Reddit API credentials (create app at https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USERNAME=your_reddit_username

# Twitter/X API v2 Bearer Token (get from developer.twitter.com/en/portal/dashboard)
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Medium Session ID (from browser cookies after logging into medium.com)
MEDIUM_SESSION_ID=your_medium_session_cookie

# Mailchimp API Key and List ID (for newsletter automation)
MAILCHIMP_API_KEY=your_mailchimp_api_key-usX
MAILCHIMP_LIST_ID=your_mailchimp_list_id
